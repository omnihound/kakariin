<p><%= link_to "← #{@pool.division.name}", @pool.division %></p>

<h1><%= @pool.name %> <span class="tag"><%= @pool.status %></span></h1>

<p class="muted">Top <%= @pool.advancing_count %> advance to the playoff bracket</p>

<p>
  <%= link_to "Edit", edit_pool_path(@pool) %>
  <%= button_to "Delete", @pool, method: :delete, class: "inline", form: { data: { turbo_confirm: "Delete this pool and its matches?" } } %>
</p>

<% if @pool.pool_matches.where(status: "completed").any? %>
  <h2>Standings</h2>
  <p class="muted">Ranked by wins, ippon difference as tiebreak.</p>

  <% standings = @pool.standings %>
  <table class="cross-table">
    <thead>
      <tr>
        <th></th>
        <% standings.each do |competitor| %>
          <th><%= competitor.full_name %></th>
        <% end %>
        <th>W–L</th>
        <th>Ipp±</th>
        <th>#</th>
      </tr>
    </thead>
    <tbody>
      <% standings.each_with_index do |row_competitor, i| %>
        <tr class="<%= "advances" if i < @pool.advancing_count %>">
          <th><%= row_competitor.full_name %></th>
          <% standings.each do |col_competitor| %>
            <% if row_competitor == col_competitor %>
              <td class="diagonal"></td>
            <% else %>
              <% match = @pool.match_between(row_competitor, col_competitor) %>
              <% if match.nil? || !match.completed? %>
                <td class="muted">–</td>
              <% else %>
                <% row_is_home = match.home == row_competitor %>
                <% row_score = row_is_home ? match.home_score : match.away_score %>
                <% col_score = row_is_home ? match.away_score : match.home_score %>
                <td>
                  <strong><%= row_score %>–<%= col_score %></strong><br>
                  <% match.ippons.select { |ip| ip.competitor_id == row_competitor.id }.each do |ippon| %>
                    <span class="mark mark-<%= ippon.technique %>"><%= technique_mark(ippon.technique) %></span>
                  <% end %>
                </td>
              <% end %>
            <% end %>
          <% end %>
          <% wins = @pool.pool_matches.count { |m| m.winner == row_competitor } %>
          <% losses = @pool.pool_matches.count { |m| (m.home == row_competitor || m.away == row_competitor) && m.completed? && m.winner != row_competitor } %>
          <td><%= wins %>–<%= losses %></td>
          <% diff = @pool.ippon_diff(row_competitor) %>
          <td><%= diff > 0 ? "+#{diff}" : diff %></td>
          <td><%= i + 1 %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <p class="muted">Highlighted rows advance to the bracket (top <%= @pool.advancing_count %>).</p>
<% end %>

<h2>Registrations</h2>

<table>
  <thead>
    <tr>
      <th>Seed</th>
      <th>Competitor</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @registrations.each do |registration| %>
      <tr>
        <td>
          <%= form_with model: registration, url: pool_registration_path(@pool, registration), method: :patch, class: "inline" do |f| %>
            <%= f.number_field :seed, value: registration.seed, size: 3 %>
            <%= f.submit "Update" %>
          <% end %>
        </td>
        <td><%= registration.competitor.full_name %></td>
        <td>
          <%= button_to "Remove", pool_registration_path(@pool, registration), method: :delete, class: "inline" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<h3>Add competitor</h3>

<%= form_with url: pool_registrations_path(@pool), scope: :pool_registration do |f| %>
  <div class="field">
    <%= f.label :competitor_id, "Competitor" %>
    <%= f.collection_select :competitor_id, @available_competitors, :id, :full_name, include_blank: true %>
  </div>
  <div class="field">
    <%= f.label :seed %>
    <%= f.number_field :seed, min: 1 %>
  </div>
  <div class="actions">
    <%= f.submit "Register" %>
  </div>
<% end %>

<h2>Matches</h2>

<% @pool.pool_matches.order(:round, :id).group_by(&:round).each do |round, matches| %>
  <h3>Round <%= round %></h3>
  <table>
    <thead>
      <tr>
        <th>Home</th>
        <th>Away</th>
        <th>Score</th>
        <th>Status</th>
        <th>Winner</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% matches.each do |match| %>
        <tr>
          <td><%= participant_name(match.home) %></td>
          <td><%= participant_name(match.away) %></td>
          <td><%= match.home_score %> – <%= match.away_score %></td>
          <td><span class="tag"><%= match.status %></span></td>
          <td>
            <% if match.winner %>
              <strong><%= participant_name(match.winner) %></strong>
            <% else %>
              <span class="muted">—</span>
            <% end %>
          </td>
          <td><%= link_to "Score", edit_match_path(match) unless match.bye? %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>