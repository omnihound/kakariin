<p><%= link_to "← #{@match.division.name}", @match.division %></p>

<h1>Round <%= @match.round %> <span class="tag"><%= @match.status %></span></h1>

<% if @match.errors.any? %>
  <div class="error-messages">
    <ul>
      <% @match.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<% if @match.division.individual? %>
  <% home_ippons = @match.ippons.order(:created_at).select { |i| i.competitor_id == @match.home.id } %>
  <% away_ippons = @match.away ? @match.ippons.order(:created_at).select { |i| i.competitor_id == @match.away.id } : [] %>

  <div class="scoreboard">
    <div class="side aka">
      <div class="side-tag">AKA</div>
      <div class="competitor-name"><%= participant_name(@match.home) %></div>
      <div class="tally"><%= @match.home_score %></div>
      <div class="marks">
        <% home_ippons.each do |ippon| %>
          <span class="mark mark-<%= ippon.technique %>">
            <%= ippon_mark(ippon) %>
            <%= button_to "×", match_ippon_path(@match, ippon), method: :delete, class: "mark-remove" %>
          </span>
        <% end %>
      </div>
      <div class="ippon-buttons"><%= ippon_buttons(match_ippons_path(@match), @match.home.id) %></div>
    </div>

    <div class="vs">–</div>

    <div class="side shiro">
      <div class="side-tag">SHIRO</div>
      <div class="competitor-name"><%= participant_name(@match.away) %></div>
      <div class="tally"><%= @match.away_score %></div>
      <div class="marks">
        <% away_ippons.each do |ippon| %>
          <span class="mark mark-<%= ippon.technique %>">
            <%= ippon_mark(ippon) %>
            <%= button_to "×", match_ippon_path(@match, ippon), method: :delete, class: "mark-remove" %>
          </span>
        <% end %>
      </div>
      <% if @match.away %>
        <div class="ippon-buttons"><%= ippon_buttons(match_ippons_path(@match), @match.away.id) %></div>
      <% end %>
    </div>
  </div>

  <% if @match.winner %>
    <p class="result-line">
      <strong><%= participant_name(@match.winner) %></strong> wins
      <% techniques = winning_techniques_label(@match.ippons, @match.winner) %>
      <%= "· #{techniques}" if techniques.present? %>
    </p>
  <% end %>
<% else %>
  <div class="scoreboard team-scoreboard">
    <div class="side aka">
      <div class="side-tag">AKA</div>
      <div class="competitor-name"><%= participant_name(@match.home) %></div>
      <div class="tally"><%= @match.home_score %></div>
    </div>
    <div class="vs">bouts –</div>
    <div class="side shiro">
      <div class="side-tag">SHIRO</div>
      <div class="competitor-name"><%= participant_name(@match.away) %></div>
      <div class="tally"><%= @match.away_score %></div>
    </div>
  </div>
  <p class="muted center">
    <%= @match.bouts.sum(&:home_score) %>–<%= @match.bouts.sum(&:away_score) %> ippons
    · <span class="tag"><%= @match.status %></span>
  </p>

  <% unless @match.completed? %>
    <p class="center"><%= button_to "Finalize match", finalize_match_path(@match), method: :post, class: "inline", form: { data: { turbo_confirm: "Lock in the result from the bouts entered so far?" } } %></p>
  <% end %>

  <table class="bout-ladder">
    <thead>
      <tr>
        <th>Position</th>
        <th><%= participant_name(@match.home) %></th>
        <th><%= participant_name(@match.away) %></th>
        <th>Score</th>
        <th>Status</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @match.bouts.order(:position).each do |bout| %>
        <tr>
          <td><%= bout.position_label %></td>
          <td>
            <%= bout.home_competitor.full_name %>
            <div class="marks">
              <% bout.ippons.where(competitor: bout.home_competitor).order(:created_at).each do |ippon| %>
                <span class="mark mark-<%= ippon.technique %>">
                  <%= ippon_mark(ippon) %>
                  <%= button_to "×", match_bout_ippon_path(@match, bout, ippon), method: :delete, class: "mark-remove" %>
                </span>
              <% end %>
            </div>
            <div class="ippon-buttons"><%= ippon_buttons(match_bout_ippons_path(@match, bout), bout.home_competitor_id) %></div>
          </td>
          <td>
            <% if bout.away_competitor %>
              <%= bout.away_competitor.full_name %>
              <div class="marks">
                <% bout.ippons.where(competitor: bout.away_competitor).order(:created_at).each do |ippon| %>
                  <span class="mark mark-<%= ippon.technique %>">
                    <%= ippon_mark(ippon) %>
                    <%= button_to "×", match_bout_ippon_path(@match, bout, ippon), method: :delete, class: "mark-remove" %>
                  </span>
                <% end %>
              </div>
              <div class="ippon-buttons"><%= ippon_buttons(match_bout_ippons_path(@match, bout), bout.away_competitor_id) %></div>
            <% else %>
              <span class="muted">forfeit</span>
            <% end %>
          </td>
          <td class="bout-result">
            <strong><%= bout.home_score %>–<%= bout.away_score %></strong>
            <% if bout.winner == bout.home_competitor %>
              ▲
            <% elsif bout.away_competitor && bout.winner == bout.away_competitor %>
              ▼
            <% elsif bout.completed? %>
              –
            <% end %>
          </td>
          <td><span class="tag"><%= bout.status %></span></td>
          <td><%= button_to "Remove", match_bout_path(@match, bout), method: :delete, class: "inline" %></td>
        </tr>
        <tr class="bout-winner-row">
          <td></td>
          <td colspan="5">
            <%= form_with url: match_bout_path(@match, bout), method: :patch, scope: :bout, class: "inline" do |f| %>
              <label><input type="radio" name="bout[winner_position]" value="home" <%= "checked" if bout.winner == bout.home_competitor %>> Home wins</label>
              <% if bout.away_competitor %>
                <label><input type="radio" name="bout[winner_position]" value="away" <%= "checked" if bout.winner == bout.away_competitor %>> Away wins</label>
              <% end %>
              <%= f.select :status, Bout.statuses.keys, selected: bout.status %>
              <%= f.submit "Save" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <h3>Add bout</h3>

  <%= form_with url: match_bouts_path(@match), scope: :bout do |f| %>
    <div class="field">
      <%= f.label :position, "Position (0 = senpo)" %>
      <%= f.number_field :position, min: 0, value: @match.bouts.count %>
    </div>
    <div class="field">
      <%= f.label :home_competitor_id, "#{participant_name(@match.home)} competitor" %>
      <%= f.collection_select :home_competitor_id, @match.home.competitors, :id, :full_name, include_blank: true %>
    </div>
    <div class="field">
      <%= f.label :away_competitor_id, "#{participant_name(@match.away)} competitor" %>
      <%= f.collection_select :away_competitor_id, @match.away.competitors, :id, :full_name, include_blank: "Forfeit" %>
    </div>
    <div class="actions">
      <%= f.submit "Add bout" %>
    </div>
  <% end %>
<% end %>

<h2>Match details</h2>

<%= form_with model: @match do |form| %>
  <% if @match.division.individual? %>
    <div class="field">
      <label>Winner</label><br>
      <label>
        <input type="radio" name="match[winner_position]" value="home" <%= "checked" if @match.winner == @match.home %>>
        <%= participant_name(@match.home) %>
      </label>
      <% if @match.away %>
        <label>
          <input type="radio" name="match[winner_position]" value="away" <%= "checked" if @match.winner == @match.away %>>
          <%= participant_name(@match.away) %>
        </label>
      <% end %>
    </div>

    <div class="field">
      <%= form.label :status %>
      <%= form.select :status, Match.statuses.keys %>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :mat_number %>
    <%= form.number_field :mat_number, min: 1 %>
  </div>

  <div class="field">
    <%= form.label :scheduled_at %>
    <%= form.datetime_field :scheduled_at %>
  </div>

  <div class="actions">
    <%= form.submit "Save" %>
  </div>
<% end %>